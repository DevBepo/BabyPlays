# Exemplo para /srv/babyplays/env/backend.env na VPS.
# Copie manualmente na VPS e nunca commite o arquivo real.

SECRET_KEY=<gere-uma-chave-forte-na-vps>
DEBUG=False
DATABASE_URL=postgres://<user>:<password>@db:5432/<db>

ALLOWED_HOSTS=api.babyplays.com.br,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://www.babyplays.com.br,https://babyplays.com.br,https://api.babyplays.com.br
CORS_ALLOWED_ORIGINS=https://www.babyplays.com.br,https://babyplays.com.br
CORS_ALLOW_CREDENTIALS=True

# Frontend e API ficam em subdominios diferentes. SameSite=None permite
# cookies de sessao/CSRF nesse fluxo cross-origin com HTTPS e Secure=True.
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=None
CSRF_COOKIE_SAMESITE=None

# Migracao inicial: manter HSTS desligado ate validar HTTPS, DNS e rollback.
SECURE_HSTS_SECONDS=0

STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media

# Ajuste conforme monitoramento real.
DRF_THROTTLE_AUTH=20/min
DRF_THROTTLE_CART=120/min
DRF_THROTTLE_CHECKOUT=20/min
DRF_THROTTLE_DELIVERY=30/min

GOOGLE_ROUTES_API_KEY=<opcional>
