# Ambiente local
# Use apenas para desenvolvimento e testes locais.
# Copie para .env somente localmente. Nunca commite .env real, secrets,
# DATABASE_URL real, tokens, cookies, certificados ou dumps de banco.

SECRET_KEY=change-me
DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# Use DATABASE_URL local se quiser PostgreSQL local.
# Se DATABASE_URL e POSTGRES_DB ficarem vazios, Django usa SQLite local.
DATABASE_URL=

# Alternativa PostgreSQL local.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=

# Opcional: calculo de rotas para entrega.
GOOGLE_ROUTES_API_KEY=

SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

# Throttling DRF. Ajuste no ambiente de producao conforme monitoramento.
DRF_THROTTLE_AUTH=100/min
DRF_THROTTLE_PASSWORD_RESET_IP=5/hour
DRF_THROTTLE_PASSWORD_RESET_EMAIL=3/hour
DRF_THROTTLE_PASSWORD_RESET_CONFIRM=10/hour
DRF_THROTTLE_CART=300/min
DRF_THROTTLE_CHECKOUT=100/min
DRF_THROTTLE_DELIVERY=120/min

# Recuperacao de senha local. O backend console imprime o e-mail no terminal.
PASSWORD_RESET_FRONTEND_URL=http://127.0.0.1:3000
PASSWORD_RESET_TIMEOUT=1800
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=BabyPlays <no-reply@babyplays.com.br>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_TIMEOUT=10
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Producao na VPS usa o exemplo separado .env.vps.example.
# O arquivo real fica protegido na VPS e nunca deve ser commitado.
