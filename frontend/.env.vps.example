# Exemplo para /srv/babyplays/env/frontend.env na VPS.
# Variaveis NEXT_PUBLIC_ ficam embutidas no build e nao devem conter segredos.

NEXT_PUBLIC_API_BASE_URL=https://api.babyplays.com.br
NEXT_PUBLIC_BABYPLAYS_WHATSAPP=<numero-publico-somente-digitos>
NEXT_PUBLIC_BABYPLAYS_INSTAGRAM_URL=<url-publica-do-instagram>

# HTTPS, DNS e rollback foram validados. O header nao inclui subdominios
# nem preload para evitar ampliar o escopo sem uma validacao separada.
FRONTEND_HSTS_SECONDS=31536000
