# Ambiente local
# Copie para .env.local somente localmente. Nunca commite .env.local.
# Variaveis NEXT_PUBLIC_ ficam visiveis no build do navegador e nao devem
# conter segredos.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_BABYPLAYS_WHATSAPP=<numero-publico-somente-digitos>
NEXT_PUBLIC_BABYPLAYS_INSTAGRAM_URL=<url-publica-do-instagram>

# Railway/homologacao
# NEXT_PUBLIC_API_BASE_URL=https://api-babyplays.up.railway.app
# NEXT_PUBLIC_BABYPLAYS_WHATSAPP=<numero-publico-somente-digitos>
# NEXT_PUBLIC_BABYPLAYS_INSTAGRAM_URL=<url-publica-do-instagram>

# Dominio final
# NEXT_PUBLIC_API_BASE_URL=https://api.babyplays.com.br
# NEXT_PUBLIC_BABYPLAYS_WHATSAPP=<numero-publico-somente-digitos>
# NEXT_PUBLIC_BABYPLAYS_INSTAGRAM_URL=<url-publica-do-instagram>
